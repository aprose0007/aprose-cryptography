import hashlib

def calculate_hash(filename):
    sha256 = hashlib.sha256()

    with open(filename, "rb") as file:
        while chunk := file.read(4096):
            sha256.update(chunk)

    return sha256.hexdigest()

file1 = input("Enter original file name: ")
file2 = input("Enter modified file name: ")

hash1 = calculate_hash(file1)
hash2 = calculate_hash(file2)

print("\nOriginal File Hash:")
print(hash1)

print("\nModified File Hash:")
print(hash2)

if hash1 == hash2:
    print("\nFiles are identical.")
else:
    print("\nTampering detected! Hashes are different.")
